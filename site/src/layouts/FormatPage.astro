---
import Base from './Base.astro';
import Nav from '../components/Nav.astro';
interface Props {
  format: 'pptx' | 'docx' | 'xlsx';
  name: string;   // "PowerPoint"
  ext: string;    // ".pptx"
  tagline: string;
  color: string;  // css var
}
const { format, name, ext, tagline, color } = Astro.props;
const title = `${name} (${ext}) — @silurus/ooxml`;
---
<Base title={title}>
  <Nav active={format} />

  <header class="fp-hero" style={`--c:${color}`}>
    <div class="wrap">
      <a class="fp-back" href="/">← All formats</a>
      <p class="eyebrow"><span class="fp-dot"></span> {name}</p>
      <h1 class="fp-title">{tagline}</h1>
      <p class="fp-lead">
        Every demo below is the real library rendering <code>{`sample-1${ext}`}</code> live in your
        browser — and the exact code that produces it. The same patterns power the Storybook stories.
      </p>
    </div>
  </header>

  <main class="wrap fp-main">
    <slot />
  </main>

  <footer class="footer">
    <div class="wrap footer-inner">
      <div class="footer-brand">
        <span class="nav-mark"><i></i><i></i><i></i></span>
        <div>
          <strong>@silurus/ooxml</strong>
          <span>Browser-based OOXML viewer · Rust/WASM + Canvas</span>
        </div>
      </div>
      <div class="footer-links">
        <a href="/">Home</a>
        <a href="https://www.npmjs.com/package/@silurus/ooxml">npm</a>
        <a href="https://github.com/yukiyokotani/office-open-xml-viewer">GitHub</a>
        <a href="/storybook/">Storybook</a>
      </div>
    </div>
  </footer>

  <script>
    import { mountDemoInto, type DemoKind, type Format } from '../lib/demos';
    const base = import.meta.env.BASE_URL;
    const url = (fmt: string) => `${base}samples/sample-1.${fmt}`.replace(/([^:])\/\/+/g, '$1/');
    const vh = () => window.innerHeight || 800;

    const blocks = Array.from(document.querySelectorAll<HTMLElement>('[data-demo]'));
    const mountAll = new URLSearchParams(location.search).has('all');
    const mount = (el: HTMLElement) => {
      if (el.dataset.mounted) return;
      el.dataset.mounted = '1';
      mountDemoInto(el, el.dataset.demo as DemoKind, el.dataset.format as Format, url(el.dataset.format as string));
    };
    const io = new IntersectionObserver((entries) => {
      for (const e of entries) if (e.isIntersecting) { mount(e.target as HTMLElement); io.unobserve(e.target); }
    }, { rootMargin: '400px' });
    for (const el of blocks) {
      if (mountAll || el.getBoundingClientRect().top < vh() + 400) mount(el);
      else io.observe(el);
    }
  </script>
</Base>

<style>
  .fp-hero { padding: 40px 0 24px; border-bottom: 1px solid var(--border); }
  .fp-back { font-size: 13px; color: var(--text-faint); }
  .fp-back:hover { color: var(--text-dim); }
  .fp-hero .eyebrow { display: flex; align-items: center; gap: 8px; margin-top: 22px; color: var(--text); font-size: 13px; text-transform: none; letter-spacing: 0; font-weight: 700; }
  .fp-dot { width: 11px; height: 11px; border-radius: 50%; background: var(--c); box-shadow: 0 0 12px -1px var(--c); }
  .fp-ext { font-family: var(--mono); font-size: 12px; color: var(--text-faint); font-weight: 500; }
  .fp-title { font-size: clamp(28px, 5vw, 44px); font-weight: 800; letter-spacing: -0.02em; margin: 10px 0 0; }
  .fp-lead { margin: 16px 0 0; max-width: 70ch; font-size: 17px; color: var(--text-dim); }
  .fp-lead code { font-family: var(--mono); font-size: 0.9em; color: var(--text); }
  .fp-main { padding-bottom: 32px; }
</style>
