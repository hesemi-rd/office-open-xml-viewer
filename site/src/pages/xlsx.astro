---
import FormatPage from '../layouts/FormatPage.astro';
import DemoBlock from '../components/DemoBlock.astro';
import FrameworkSection from '../components/FrameworkSection.astro';
import ApiReference from '../components/ApiReference.astro';
import { xlsxSheetSnippet } from '../lib/demo-snippets';
---
<FormatPage format="xlsx" name="XLSX" ext=".xlsx" color="var(--xlsx)"
  tagline="Render .xlsx workbooks to Canvas, your way.">
  <DemoBlock
    format="xlsx" kind="sheet" badge="Story · Demo"
    title="The full workbook viewer"
    description="Unlike slides and pages, a spreadsheet is one continuous grid — so XlsxViewer owns its own canvas, sheet-tab bar and zoom slider. Switch sheets along the bottom, click-drag to select a range, press Ctrl/Cmd+C to copy it as TSV, and drag the zoom slider (10–400%)."
    code={xlsxSheetSnippet}
  />
  <FrameworkSection format="xlsx" />
  <ApiReference format="xlsx" />
</FormatPage>
