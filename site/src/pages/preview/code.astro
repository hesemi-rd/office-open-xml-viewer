---
import CodeTabs from '../../components/CodeTabs.astro';
import {
  embedSnippet, scrollSnippet, thumbnailSnippet, navSnippet, fileSnippet, selectionSnippet,
  vanillaSnippet, reactSnippet, vueSnippet, svelteSnippet,
} from '../../lib/snippets';
import '../../styles/global.css';
const recipeTabs = [
  { id: 'embed', label: 'Embed a viewer', lang: 'ts', code: embedSnippet },
  { id: 'scroll', label: 'Scroll every page', lang: 'ts', code: scrollSnippet },
  { id: 'thumbs', label: 'Thumbnail grid', lang: 'ts', code: thumbnailSnippet },
  { id: 'nav', label: 'Page controls', lang: 'ts', code: navSnippet },
  { id: 'file', label: 'Open a local file', lang: 'ts', code: fileSnippet },
  { id: 'select', label: 'Select & copy', lang: 'ts', code: selectionSnippet },
];
const frameworkTabs = [
  { id: 'react', label: 'React', lang: 'tsx', code: reactSnippet },
  { id: 'vue', label: 'Vue', lang: 'vue', code: vueSnippet },
  { id: 'svelte', label: 'Svelte', lang: 'svelte', code: svelteSnippet },
  { id: 'vanilla', label: 'Vanilla', lang: 'ts', code: vanillaSnippet },
];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" /><title>preview: code</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
  </head>
  <body style="padding:24px;">
    <div style="max-width:900px;margin:0 auto;display:grid;gap:28px;">
      <CodeTabs tabs={recipeTabs} filename="example.ts" />
      <CodeTabs tabs={frameworkTabs} filename="Deck.tsx" />
    </div>
  </body>
</html>
