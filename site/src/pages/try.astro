---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
---
<Base title="Try your own file — @silurus/ooxml">
  <Nav />

  <header class="try-hero">
    <div class="wrap">
      <p class="eyebrow">Try it on your own document</p>
      <h1 class="try-title">Drop in a file. See exactly how it renders.</h1>
      <p class="try-lead">
        Pick one of your own <strong>.docx</strong>, <strong>.xlsx</strong> or <strong>.pptx</strong> files
        and the library renders it right here. Everything runs in your browser — your file is parsed by
        WebAssembly on this page and <strong>never uploaded anywhere</strong>.
      </p>
    </div>
  </header>

  <main class="wrap try-main">
    <label class="dropzone" id="dropzone">
      <input type="file" id="file" accept=".docx,.xlsx,.pptx" hidden />
      <div class="dz-inner">
        <div class="dz-icon">⬆</div>
        <p class="dz-title">Drop a file here, or <span class="dz-link">browse</span></p>
        <p class="dz-hint">.docx · .xlsx · .pptx — processed locally, never uploaded</p>
      </div>
    </label>

    <div class="try-status" id="status" hidden></div>

    <div class="try-panel" id="panel" hidden>
      <div class="try-panel-head">
        <span class="try-file" id="panel-file"></span>
        <span class="panel-badge">live · WASM</span>
        <button class="try-reset" id="reset">Try another →</button>
      </div>
      <div class="try-stage" id="stage"></div>
    </div>

    <p class="try-fineprint">
      No file leaves your device. <a class="inline-link" href="https://github.com/yukiyokotani/office-open-xml-viewer">See the source</a>
      if you'd rather verify that yourself.
    </p>
  </main>

  <footer class="footer">
    <div class="wrap footer-inner">
      <div class="footer-brand">
        <span class="nav-mark"><i></i><i></i><i></i></span>
        <div>
          <strong>@silurus/ooxml</strong>
          <span>Browser-based OOXML viewer · Rust/WASM + Canvas</span>
        </div>
      </div>
      <div class="footer-links">
        <a href="/">Home</a>
        <a href="https://www.npmjs.com/package/@silurus/ooxml">npm</a>
        <a href="https://github.com/yukiyokotani/office-open-xml-viewer">GitHub</a>
        <a href="/storybook/">Storybook</a>
      </div>
    </div>
  </footer>

  <script>
    import { renderFile } from '../lib/try';
    const dz = document.getElementById('dropzone') as HTMLLabelElement;
    const input = document.getElementById('file') as HTMLInputElement;
    const status = document.getElementById('status') as HTMLElement;
    const panel = document.getElementById('panel') as HTMLElement;
    const stage = document.getElementById('stage') as HTMLElement;
    const fileLabel = document.getElementById('panel-file') as HTMLElement;
    const reset = document.getElementById('reset') as HTMLButtonElement;

    async function handle(file: File): Promise<void> {
      status.hidden = false;
      status.classList.remove('error');
      status.textContent = `Parsing ${file.name}…`;
      panel.hidden = true;
      try {
        const t0 = performance.now();
        const res = await renderFile(stage, file);
        const ms = Math.round(performance.now() - t0);
        const count = res.units ? `${res.units} ${res.unitLabel}${res.units === 1 ? '' : 's'} · ` : '';
        fileLabel.textContent = file.name;
        status.hidden = true;
        panel.hidden = false;
        status.textContent = `${count}rendered in ${ms} ms`;
        status.hidden = false;
      } catch (e) {
        status.classList.add('error');
        status.textContent = e instanceof Error ? e.message : String(e);
        panel.hidden = true;
      }
    }

    // Reset the value after capturing the file so re-selecting the SAME file
    // fires `change` again. Returning to this page via browser back/forward
    // reloads it but Chromium restores the file input's value to the previously
    // chosen file; without this reset, re-picking that same file emits no
    // `change` event and nothing renders.
    input.addEventListener('change', () => {
      const f = input.files?.[0];
      input.value = '';
      if (f) void handle(f);
    });
    ['dragenter', 'dragover'].forEach((ev) =>
      dz.addEventListener(ev, (e) => { e.preventDefault(); dz.classList.add('over'); }));
    ['dragleave', 'drop'].forEach((ev) =>
      dz.addEventListener(ev, (e) => { e.preventDefault(); dz.classList.remove('over'); }));
    dz.addEventListener('drop', (e) => {
      const f = (e as DragEvent).dataTransfer?.files?.[0];
      if (f) void handle(f);
    });
    reset.addEventListener('click', () => { input.value = ''; input.click(); });
  </script>
</Base>

<style>
  .try-hero { padding: 48px 0 8px; }
  .try-title { font-size: clamp(28px, 5vw, 46px); font-weight: 800; letter-spacing: -0.02em; margin: 14px 0 0; }
  .try-lead { margin: 16px 0 0; max-width: 64ch; font-size: 17px; color: var(--text-dim); }
  .try-lead strong { color: var(--text); }
  .try-main { padding: 28px 0 16px; }

  .dropzone {
    display: block;
    border: 1.5px dashed var(--border-bright);
    border-radius: 18px;
    background: var(--bg-elev);
    padding: 56px 24px;
    text-align: center;
    cursor: pointer;
    transition: border-color 0.18s, background 0.18s, transform 0.18s;
  }
  .dropzone:hover { border-color: var(--accent); }
  .dropzone.over { border-color: var(--accent); background: rgba(94, 234, 212, 0.06); transform: scale(1.005); }
  .dz-icon {
    width: 56px; height: 56px; margin: 0 auto 16px;
    display: grid; place-items: center;
    font-size: 24px; border-radius: 50%;
    background: var(--bg-elev-2); border: 1px solid var(--border-bright); color: var(--accent);
  }
  .dz-title { font-size: 18px; font-weight: 600; margin: 0; }
  .dz-link { color: var(--accent); text-decoration: underline; text-underline-offset: 2px; }
  .dz-hint { font-family: var(--mono); font-size: 12.5px; color: var(--text-faint); margin: 8px 0 0; }

  .try-status {
    margin-top: 16px; font-family: var(--mono); font-size: 13px; color: var(--text-dim);
    text-align: center;
  }
  .try-status.error { color: #f87171; }

  .try-panel {
    margin-top: 20px;
    border: 1px solid var(--border);
    border-radius: 14px;
    background: var(--panel);
    overflow: hidden;
    box-shadow: var(--glow);
  }
  .try-panel-head {
    display: flex; align-items: center; gap: 12px;
    padding: 10px 16px; border-bottom: 1px solid var(--border); background: var(--bg-elev);
  }
  .try-file { font-family: var(--mono); font-size: 13px; color: var(--text-dim); }
  .panel-badge {
    font-family: var(--mono); font-size: 11px; color: var(--accent);
    border: 1px solid var(--border-bright); border-radius: 999px; padding: 3px 10px;
  }
  .try-reset {
    margin-left: auto; appearance: none; cursor: pointer;
    background: var(--bg-elev-2); border: 1px solid var(--border-bright); color: var(--text-dim);
    font-size: 12.5px; padding: 6px 12px; border-radius: 8px; transition: border-color 0.15s, color 0.15s;
  }
  .try-reset:hover { border-color: var(--accent); color: var(--text); }
  .try-stage :global(.lv-scroll), .try-stage :global(.lv-xlsx) { border-radius: 0; }

  .try-fineprint { margin-top: 18px; font-size: 13px; color: var(--text-faint); text-align: center; }
</style>
