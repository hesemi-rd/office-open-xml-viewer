---
import CodeTabs from './CodeTabs.astro';
import { frameworkSnippets } from '../lib/demo-snippets';
interface Props {
  format: 'docx' | 'xlsx' | 'pptx';
}
const { format } = Astro.props;
const s = frameworkSnippets[format];
const tabs = [
  { id: 'react', label: 'React', lang: 'tsx', code: s.react },
  { id: 'vue', label: 'Vue', lang: 'vue', code: s.vue },
  { id: 'svelte', label: 'Svelte', lang: 'svelte', code: s.svelte },
  { id: 'vanilla', label: 'Vanilla', lang: 'ts', code: s.vanilla },
];
---
<section class="fw-section" data-reveal>
  <p class="demo-badge">In your framework</p>
  <h3 class="demo-title">Mount it in {format === 'xlsx' ? 'a container' : 'a canvas'}</h3>
  <p class="demo-desc">
    The viewer is a plain TypeScript class — no framework runtime, no peer deps. Create it on mount,
    call <code>load()</code>, and let it go on unmount.
  </p>
  <CodeTabs tabs={tabs} />
</section>

<style>
  .fw-section { padding: 40px 0 8px; border-top: 1px solid var(--border); }
  .demo-badge {
    font-family: var(--mono); font-size: 12px; letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--accent); margin: 0;
  }
  .demo-title { font-size: 24px; font-weight: 700; margin: 8px 0 8px; }
  .demo-desc { color: var(--text-dim); font-size: 16px; max-width: 70ch; margin: 0 0 22px; }
  .demo-desc code { font-family: var(--mono); font-size: 0.9em; color: var(--text); }
</style>
