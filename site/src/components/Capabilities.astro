---
const cols = [
  {
    name: 'DOCX', ext: '.docx', color: 'var(--docx)',
    items: [
      'Headers / footers, section breaks',
      'Tables — borders, fills, merges',
      'Images & SVG, inline & anchored with text wrap',
      'Ruby / furigana, sub/superscript',
      'Line grid (docGrid), spacing rules',
      'Lists, paragraph & table styles',
      'Math equations (OMML, STIX Two Math)',
      'Track changes, footnote markers',
      'Native text selection & copy',
    ],
  },
  {
    name: 'XLSX', ext: '.xlsx', color: 'var(--xlsx)',
    items: [
      'Multiple sheets, tab colours',
      'Formulas (cached), dates, number formats',
      'Charts — bar, line, area, pie, doughnut, radar, scatter',
      'Sparklines, conditional formatting',
      'Merged cells, frozen panes, kinsoku cell wrap',
      'Cell comments, list data validation',
      'Selection, TSV copy, zoom slider',
      'Images & SVG, drawing shapes, slicers',
      'Math equations (OMML, STIX Two Math)',
    ],
  },
  {
    name: 'PPTX', ext: '.pptx', color: 'var(--pptx)',
    items: [
      'Layout / master inheritance',
      'Backgrounds — solid, gradient, image',
      'Preset & custom geometry shapes',
      'Shape & picture effects — shadows, glow, reflection',
      '3D scene camera, bevel & extrusion shading (sp3d)',
      'Charts with axis & label styling',
      'Math equations (OMML, STIX Two Math)',
      'SmartArt text, grouped transforms',
      'SVG images, gradient / image fills, theme colours',
      'Japanese kinsoku line breaking, native text selection',
    ],
  },
];
---
<div class="caps-grid">
  {cols.map((col) => (
    <div class="caps-col" style={`--c:${col.color}`}>
      <div class="caps-head"><span class="caps-dot"></span> {col.name}</div>
      <ul>
        {col.items.map((it) => <li set:html={it} />)}
      </ul>
      <a class="caps-link" href={col.ext.replace('.', '/')}>{col.name} demos &amp; code →</a>
    </div>
  ))}
</div>

<style>
  .caps-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; margin-top: 32px; }
  .caps-col {
    border: 1px solid var(--border);
    border-radius: 14px;
    background: var(--panel);
    padding: 22px 22px 8px;
  }
  .caps-head { display: flex; align-items: center; gap: 8px; font-weight: 700; font-size: 17px; margin-bottom: 14px; }
  .caps-ext { font-family: var(--mono); font-size: 12px; color: var(--text-faint); font-weight: 500; }
  .caps-dot { width: 10px; height: 10px; border-radius: 50%; background: var(--c); box-shadow: 0 0 10px -1px var(--c); }
  .caps-col ul { list-style: none; margin: 0; padding: 0; }
  .caps-col li {
    position: relative;
    padding: 7px 0 7px 24px;
    font-size: 14px;
    color: var(--text-dim);
    border-top: 1px solid var(--border);
  }
  .caps-col li:first-child { border-top: none; }
  .caps-col li::before { content: '✓'; position: absolute; left: 0; top: 7px; color: var(--c); font-weight: 700; }
  .caps-link {
    display: inline-block;
    margin: 14px 0 16px;
    font-size: 13.5px;
    font-weight: 600;
    color: var(--c);
    transition: opacity 0.15s;
  }
  .caps-link:hover { opacity: 0.75; }
  @media (max-width: 860px) { .caps-grid { grid-template-columns: 1fr; } }
</style>
