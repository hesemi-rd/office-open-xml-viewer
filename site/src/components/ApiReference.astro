---
import { apiReference } from '../lib/api-reference';
interface Props {
  format: 'docx' | 'xlsx' | 'pptx';
}
const { format } = Astro.props;
const classes = apiReference[format];
---
<section class="api" data-reveal>
  <p class="api-badge">API reference</p>
  <h3 class="api-title">Options &amp; methods</h3>
  <p class="api-desc">
    Every public option and method, straight from the source. Types omitted for brevity are exported
    from the package — your editor will autocomplete the rest.
  </p>

  {classes.map((c) => (
    <div class="api-class">
      <h4 class="api-class-name">{c.name}</h4>
      {c.note && <p class="api-note">{c.note}</p>}
      <pre class="api-ctor"><code>{c.ctor}</code></pre>

      {c.options && c.options.length > 0 && (
        <>
          <p class="api-sub">Options</p>
          <div class="api-table-wrap">
            <table class="api-table">
              <thead><tr><th>Option</th><th>Type</th><th>Default</th><th>Description</th></tr></thead>
              <tbody>
                {c.options.map((o) => (
                  <tr>
                    <td><code>{o.name}</code></td>
                    <td><code class="api-type">{o.type}</code></td>
                    <td>{o.def ? <code>{o.def}</code> : <span class="api-dash">—</span>}</td>
                    <td>{o.desc}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </>
      )}

      <p class="api-sub">Methods</p>
      <div class="api-table-wrap">
        <table class="api-table">
          <tbody>
            {c.methods.map((m) => (
              <tr>
                <td class="api-sig"><code>{m.sig}</code></td>
                <td>{m.desc}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  ))}
</section>

<style>
  .api { padding: 40px 0 8px; border-top: 1px solid var(--border); }
  .api-badge {
    font-family: var(--mono); font-size: 12px; letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--accent); margin: 0;
  }
  .api-title { font-size: 24px; font-weight: 700; margin: 8px 0 8px; }
  .api-desc { color: var(--text-dim); font-size: 16px; max-width: 70ch; margin: 0 0 8px; }

  .api-class { margin-top: 30px; }
  .api-class-name { font-family: var(--mono); font-size: 18px; font-weight: 700; margin: 0; }
  .api-note { color: var(--text-dim); font-size: 14.5px; margin: 8px 0 12px; max-width: 74ch; }
  .api-ctor {
    margin: 0 0 18px; padding: 12px 16px; overflow-x: auto;
    background: #0d1117; border: 1px solid var(--border); border-radius: 10px;
  }
  .api-ctor code { font-family: var(--mono); font-size: 13px; color: var(--accent); }

  .api-sub {
    font-size: 12px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase;
    color: var(--text-faint); margin: 16px 0 8px;
  }
  .api-table-wrap { overflow-x: auto; border: 1px solid var(--border); border-radius: 10px; }
  .api-table { width: 100%; border-collapse: collapse; font-size: 14px; }
  .api-table th {
    text-align: left; font-weight: 600; color: var(--text-dim); font-size: 12px;
    text-transform: uppercase; letter-spacing: 0.04em;
    padding: 10px 14px; border-bottom: 1px solid var(--border); background: var(--bg-elev);
  }
  .api-table td { padding: 10px 14px; border-top: 1px solid var(--border); color: var(--text-dim); vertical-align: top; }
  .api-table tbody tr:first-child td { border-top: none; }
  .api-table code { font-family: var(--mono); font-size: 12.5px; color: var(--text); white-space: nowrap; }
  .api-table .api-type { color: var(--accent-2); white-space: normal; }
  .api-sig code { color: var(--accent); white-space: normal; }
  .api-dash { color: var(--text-faint); }
</style>
