{
  "name": "@silurus/ooxml-xlsx",
  "private": true,
  "version": "0.57.0",
  "description": "XLSX parser and Canvas renderer (internal workspace package of @silurus/ooxml)",
  "license": "MIT",
  "author": "Yuki Yokotani <silurus.dev@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yukiyokotani/office-open-xml-viewer.git",
    "directory": "packages/xlsx"
  },
  "homepage": "https://github.com/yukiyokotani/office-open-xml-viewer#readme",
  "bugs": {
    "url": "https://github.com/yukiyokotani/office-open-xml-viewer/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/types/index.d.ts"
    },
    "./wasm": "./src/wasm/xlsx_parser.js",
    "./wasm-binary": "./src/wasm/xlsx_parser_bg.wasm"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "wasm": "cd parser && wasm-pack build --target web --out-dir ../src/wasm",
    "typecheck": "tsc --noEmit",
    "vrt": "playwright test --config playwright.config.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/pngjs": "^6.0.5",
    "pixelmatch": "^7.1.0",
    "playwright": "^1.59.1",
    "pngjs": "^7.0.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vite-plugin-wasm": "^3.6.0"
  },
  "dependencies": {
    "@silurus/ooxml-core": "workspace:*"
  }
}
