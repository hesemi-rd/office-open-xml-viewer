{
  "name": "@silurus/ooxml-markdown",
  "version": "0.70.2",
  "description": "Convert .pptx / .docx / .xlsx to GitHub-flavoured markdown using the workspace WASM parsers — browser / Node / CLI",
  "license": "MIT",
  "author": "Yuki Yokotani <silurus.dev@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yukiyokotani/office-open-xml-viewer.git",
    "directory": "packages/markdown"
  },
  "homepage": "https://github.com/yukiyokotani/office-open-xml-viewer#readme",
  "bugs": {
    "url": "https://github.com/yukiyokotani/office-open-xml-viewer/issues"
  },
  "keywords": [
    "ooxml",
    "docx",
    "xlsx",
    "pptx",
    "markdown",
    "convert",
    "llm",
    "wasm",
    "cli"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "bin": {
    "ooxml-md": "./bin/ooxml-md.mjs"
  },
  "files": [
    "src",
    "bin"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json"
  },
  "dependencies": {
    "@silurus/ooxml-docx": "workspace:*",
    "@silurus/ooxml-pptx": "workspace:*",
    "@silurus/ooxml-xlsx": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.2"
  }
}
