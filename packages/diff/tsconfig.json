{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "declarationDir": "./dist/types",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "paths": {
      "@silurus/ooxml-core": ["../core/src/index.ts"],
      "@silurus/ooxml-pptx": ["../pptx/src/types.ts"],
      "@silurus/ooxml-docx": ["../docx/src/types.ts"],
      "@silurus/ooxml-xlsx": ["../xlsx/src/types.ts"]
    }
  },
  "include": ["src"],
  "references": [
    { "path": "../core" },
    { "path": "../pptx" },
    { "path": "../docx" },
    { "path": "../xlsx" }
  ]
}
