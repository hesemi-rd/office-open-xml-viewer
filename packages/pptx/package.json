{
  "name": "@silurus/ooxml-pptx",
  "private": true,
  "version": "0.72.0",
  "description": "PPTX parser and Canvas renderer (internal workspace package of @silurus/ooxml)",
  "license": "MIT",
  "author": "Yuki Yokotani <silurus.dev@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yukiyokotani/office-open-xml-viewer.git",
    "directory": "packages/pptx"
  },
  "homepage": "https://github.com/yukiyokotani/office-open-xml-viewer#readme",
  "bugs": {
    "url": "https://github.com/yukiyokotani/office-open-xml-viewer/issues"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/types/index.d.ts"
    },
    "./wasm": "./src/wasm/pptx_parser.js",
    "./wasm-binary": "./src/wasm/pptx_parser_bg.wasm"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc --build && vite build",
    "preview": "vite preview",
    "wasm": "cd parser && wasm-pack build --target web --out-dir ../src/wasm && node ../../../scripts/append-wasm-reinit.mjs ../src/wasm/pptx_parser.js",
    "vrt": "playwright test --config playwright.config.ts",
    "vrt:worker": "playwright test --config playwright.config.ts worker-equivalence"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/pngjs": "^6.0.5",
    "@vitest/coverage-v8": "^4.1.4",
    "pixelmatch": "^7.1.0",
    "playwright": "^1.59.1",
    "pngjs": "^7.0.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@fontsource/nunito-sans": "^5.2.7",
    "@silurus/ooxml-core": "workspace:*"
  }
}
