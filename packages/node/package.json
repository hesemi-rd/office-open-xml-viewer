{
  "name": "@silurus/ooxml-node",
  "private": true,
  "version": "0.69.0",
  "description": "Node-side parsers for OOXML (docx/xlsx/pptx) using the workspace WASM artifacts — no browser DOM needed",
  "license": "MIT",
  "author": "Yuki Yokotani <silurus.dev@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yukiyokotani/office-open-xml-viewer.git",
    "directory": "packages/node"
  },
  "homepage": "https://github.com/yukiyokotani/office-open-xml-viewer#readme",
  "bugs": {
    "url": "https://github.com/yukiyokotani/office-open-xml-viewer/issues"
  },
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./pptx": "./src/pptx.ts",
    "./docx": "./src/docx.ts",
    "./xlsx": "./src/xlsx.ts"
  },
  "bin": {
    "ooxml-thumbnail": "./bin/ooxml-thumbnail.mjs"
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json"
  },
  "dependencies": {
    "@silurus/ooxml-pptx": "workspace:*",
    "@silurus/ooxml-docx": "workspace:*",
    "@silurus/ooxml-xlsx": "workspace:*"
  },
  "peerDependencies": {
    "skia-canvas": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "skia-canvas": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.2"
  }
}
