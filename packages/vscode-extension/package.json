{
  "name": "office-open-xml-viewer",
  "displayName": "Office Viewer — DOCX, XLSX, PPTX",
  "description": "High-fidelity viewer for Office files (.docx / .xlsx / .pptx). Local-only — files never leave your machine. Powered by a Rust/WASM parser and Canvas renderer.",
  "version": "0.32.1",
  "publisher": "silurus",
  "license": "MIT",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.101.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "keywords": [
    "ooxml",
    "docx",
    "xlsx",
    "pptx",
    "office",
    "viewer",
    "word",
    "excel",
    "powerpoint"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/yukiyokotani/office-open-xml-viewer"
  },
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "ooxmlViewer.docxEditor",
        "displayName": "OOXML Viewer (DOCX)",
        "selector": [
          { "filenamePattern": "*.docx" }
        ],
        "priority": "default"
      },
      {
        "viewType": "ooxmlViewer.xlsxEditor",
        "displayName": "OOXML Viewer (XLSX)",
        "selector": [
          { "filenamePattern": "*.xlsx" }
        ],
        "priority": "default"
      },
      {
        "viewType": "ooxmlViewer.pptxEditor",
        "displayName": "OOXML Viewer (PPTX)",
        "selector": [
          { "filenamePattern": "*.pptx" }
        ],
        "priority": "default"
      }
    ],
    "commands": [
      {
        "command": "ooxmlViewer.copySelection",
        "title": "Copy Selection",
        "category": "OOXML Viewer"
      },
      {
        "command": "ooxmlViewer.installMcpServer",
        "title": "Install / Enable MCP Server",
        "category": "OOXML Viewer"
      },
      {
        "command": "ooxmlViewer.disableMcpServer",
        "title": "Disable MCP Server",
        "category": "OOXML Viewer"
      }
    ],
    "mcpServerDefinitionProviders": [
      {
        "id": "ooxml-mcp",
        "label": "OOXML (Word / Excel / PowerPoint)"
      }
    ],
    "configuration": {
      "title": "OOXML Viewer",
      "properties": {
        "ooxmlViewer.mcpServer.enabled": {
          "type": "string",
          "enum": ["auto", "always", "never"],
          "enumDescriptions": [
            "Offer to enable when the workspace contains .xlsx / .docx / .pptx files.",
            "Always register the MCP server (downloading the binary on first use).",
            "Never register the MCP server."
          ],
          "default": "auto",
          "description": "Controls when the OOXML MCP server is registered with AI agents (Copilot, Claude, etc.). The server lets agents read .xlsx / .docx / .pptx files via dedicated tools instead of unzipping XML by hand."
        },
        "ooxmlViewer.mcpServer.binaryPath": {
          "type": "string",
          "default": "",
          "description": "Optional absolute path to a pre-installed `ooxml-mcp-server` binary (e.g. one installed via `cargo install`). When empty, the extension downloads a prebuilt binary on demand."
        }
      }
    }
  },
  "scripts": {
    "compile": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "vscode:prepublish": "node esbuild.config.mjs --production",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.101.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@silurus/ooxml-docx": "workspace:*",
    "@silurus/ooxml-xlsx": "workspace:*",
    "@silurus/ooxml-pptx": "workspace:*"
  }
}
